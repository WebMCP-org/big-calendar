# WebMCP Calendar Demo - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# ANTHROPIC API KEY (Required for Development Mode)
# =============================================================================
# Get your API key from: https://console.anthropic.com/
# This is used by the embedded agent in development mode to make API calls.
#
# IMPORTANT: This key is exposed to the client (NEXT_PUBLIC_ prefix).
# For production, use WebMCP's hosted solution instead of devMode.
# See: https://webmcp.ai

NEXT_PUBLIC_ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# =============================================================================
# PRODUCTION SETUP (Optional)
# =============================================================================
# For production deployment, you should:
# 1. Remove the devMode prop from CalendarEmbeddedAgent
# 2. Use your WebMCP app ID from https://webmcp.ai
# 3. Remove this environment variable (not needed in production mode)
